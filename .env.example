# Site URL
SITE_URL="https://king3-me.vercel.app"

# Supabase
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-REGION].pooler.supabase.com:[YOUR-DATABASE-PORT]/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-REGION].pooler.supabase.com:[YOUR-DATABASE-PORT]/postgres"

# Better Auth
BETTER_AUTH_URL="[YOUR-URL]"
BETTER_AUTH_SECRET="[YOUR-SECRET]" # openssl rand -base64 32

# OAuth
GOOGLE_CLIENT_ID="[YOUR-GOOGLE-ID]"
GOOGLE_CLIENT_SECRET="[YOUR-GOOGLE-SECRET]"
GITHUB_CLIENT_ID="[YOUR-GITHUB-ID]"
GITHUB_CLIENT_SECRET="[YOUR-GITHUB-SECRET]"
